// Firebase Storage Security Rules
// ─────────────────────────────────────────────────────────────
// Go to: https://console.firebase.google.com/project/bvp-hack-870c7/storage/rules
// Click "Edit rules" and REPLACE everything with this:

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow anyone authenticated to read
      allow read: if true;
      // Allow anyone authenticated to write (for now — tighten later)
      allow write: if request.auth != null;
    }
  }
}
